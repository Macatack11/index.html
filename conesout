<script>
/* On-page error reporter — installed before any app code runs, so ANY JS error anywhere
   (including ones that would otherwise fail silently) shows up as a visible banner on the
   page itself. No DevTools needed: just screenshot the app. */
(function(){
  var errorLog = [];
  function renderBanner(){
    var el = document.getElementById("__err_banner__");
    if(!el){
      el = document.createElement("div");
      el.id = "__err_banner__";
      el.style.cssText = "position:fixed;top:0;left:0;right:0;z-index:99999;background:#3a0d0d;color:#ffb3b3;font:12px/1.4 monospace;padding:10px 12px;max-height:45vh;overflow:auto;border-bottom:3px solid #ff5d5d;white-space:pre-wrap;";
      document.addEventListener("DOMContentLoaded", function(){ document.body.appendChild(el); });
      if(document.body) document.body.appendChild(el);
    }
    el.textContent = "APP ERROR (" + errorLog.length + ") — screenshot this banner:\n\n" + errorLog.join("\n---\n");
  }
  window.addEventListener("error", function(e){
    errorLog.push((e.message || "Unknown error") + "\nat " + (e.filename || "?") + ":" + (e.lineno || "?") + ":" + (e.colno || "?"));
    renderBanner();
  });
  window.addEventListener("unhandledrejection", function(e){
    errorLog.push("Unhandled promise rejection: " + (e.reason && e.reason.message ? e.reason.message : e.reason));
    renderBanner();
  });
})();
</script>
