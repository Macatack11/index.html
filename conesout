<style>
:root{
  --navy1:#0d1f35;
  --navy2:#111827;
  --navy3:#1e2d45;
  --cyan:#32CCFE;
  --cyan-dim:#1c8fb0;
  --text:#e8f1f8;
  --muted:#8fa3bd;
  --red:#ff5d5d;
  --amber:#ffb547;
  --green:#4ade80;
  --border:#2a3d5c;
  --radius:12px;
}
*{box-sizing:border-box;margin:0;padding:0;-webkit-tap-highlight-color:transparent;}
html,body{height:100%;overflow:hidden;overscroll-behavior:none;}
body{
  background:var(--navy1);
  color:var(--text);
  font-family:'Barlow',sans-serif;
  font-size:16px;
  line-height:1.4;
}
h1,h2,h3,h4,.heading{
  font-family:'Barlow Condensed',sans-serif;
  font-weight:600;
  letter-spacing:0.3px;
}
/* App shell is a fixed-height flex column: header (auto) / scrollable content (flex:1) / action bar (auto) / bottom nav (auto).
   Only #screen-container scrolls. Nothing can ever be hidden behind the bottom nav because the nav is a normal
   flex item taking real space, not an overlay — this replaces the earlier padding-based approach entirely. */
#app-shell{
  max-width:480px;
  margin:0 auto;
  height:100vh;
  height:100dvh;
  display:flex;
  flex-direction:column;
  background:var(--navy1);
  overflow:hidden;
}
#screen-container{
  flex:1 1 auto;
  min-height:0; /* required for flex children to actually scroll instead of overflowing */
  overflow-y:auto;
  -webkit-overflow-scrolling:touch;
}
.hidden{display:none !important;}
.screen{display:none;padding:16px 16px 24px;}
.screen.active{display:block;}

/* ---------- Login ---------- */
#login-overlay{
  position:fixed;inset:0;z-index:500;
  background:radial-gradient(circle at 50% 20%, var(--navy3), var(--navy1) 70%);
  display:flex;align-items:center;justify-content:center;
  padding:24px;
}
.login-card{
  width:100%;max-width:360px;
  background:var(--navy2);
  border:1px solid var(--border);
  border-radius:var(--radius);
  padding:28px 24px;
}
.login-logo{
  text-align:center;margin-bottom:22px;
}
.login-logo .mark{
  font-family:'Barlow Condensed',sans-serif;
  font-size:34px;font-weight:700;color:var(--cyan);
  letter-spacing:1px;
}
.login-logo .sub{color:var(--muted);font-size:13px;margin-top:2px;}
.field{margin-bottom:14px;}
.field label{
  display:block;font-size:12px;color:var(--muted);
  text-transform:uppercase;letter-spacing:0.5px;margin-bottom:6px;
}
.field input, .field select, .field textarea{
  width:100%;
  background:var(--navy3);
  border:1px solid var(--border);
  color:var(--text);
  border-radius:8px;
  padding:12px 12px;
  font-size:16px;
  font-family:inherit;
}
.field input:focus, .field select:focus, .field textarea:focus{
  outline:none;border-color:var(--cyan);
}
.btn{
  display:inline-flex;align-items:center;justify-content:center;
  gap:8px;
  border:none;border-radius:10px;
  padding:13px 18px;
  font-family:'Barlow Condensed',sans-serif;
  font-size:17px;font-weight:600;letter-spacing:0.4px;
  cursor:pointer;
  width:100%;
}
.btn-primary{background:var(--cyan);color:#05202b;}
.btn-primary:disabled{background:var(--navy3);color:var(--muted);cursor:not-allowed;}
.btn-secondary{background:var(--navy3);color:var(--text);border:1px solid var(--border);}
.btn-danger{background:var(--red);color:#2b0505;}
.btn-ghost{background:transparent;color:var(--cyan);border:1px solid var(--cyan-dim);}
.btn-sm{padding:9px 12px;font-size:14px;width:auto;}
#login-error{
  color:var(--red);font-size:13px;margin-top:10px;min-height:16px;text-align:center;
}
.login-hint{
  margin-top:16px;text-align:center;color:var(--muted);font-size:12px;
}
</style>
</head>
<body>
<div id="app-shell">

<!-- ================= LOGIN OVERLAY ================= -->
<div id="login-overlay">
  <div class="login-card">
    <div class="login-logo">
      <div class="mark">ConesOut<span style="font-size:16px;vertical-align:top;">&reg;</span></div>
      <div class="sub">Road Works Setup Assistant</div>
    </div>
    <form id="login-form">
      <div class="field">
        <label for="login-username">Username</label>
        <input type="text" id="login-username" autocomplete="username" autocapitalize="none" required>
      </div>
      <div class="field">
        <label for="login-passcode">Passcode</label>
        <input type="password" id="login-passcode" autocomplete="current-password" required>
      </div>
      <button type="submit" class="btn btn-primary" id="login-submit-btn">Log In</button>
      <div id="login-error"></div>
    </form>
    <div class="login-hint">CoP 2013 &amp; Chapter 8 compliant setup guidance</div>
    <div class="login-hint" style="margin-top:6px;font-size:11px;">Logging in means you accept the ConesOut Terms of Use (Reference tab). ConesOut supports trained operatives - it is not a substitute for your qualifications, your training, or your own judgement on site.</div>
  </div>
</div>
<style>
/* ---------- Top bar ---------- */
#top-bar{
  display:flex;align-items:center;justify-content:space-between;
  padding:14px 16px;border-bottom:1px solid var(--border);
  background:var(--navy1);flex-shrink:0;
}
#top-bar .brand{font-family:'Barlow Condensed',sans-serif;font-size:22px;font-weight:700;color:var(--cyan);}
#top-bar .user-chip{font-size:12px;color:var(--muted);text-align:right;}
#top-bar .user-chip button{
  background:none;border:none;color:var(--red);font-size:12px;
  text-decoration:underline;cursor:pointer;padding:0;margin-top:2px;font-family:inherit;
}

/* ---------- Generic ---------- */
.card{
  background:var(--navy2);border:1px solid var(--border);
  border-radius:var(--radius);padding:16px;margin-bottom:14px;
}
.section-title{
  font-size:13px;text-transform:uppercase;letter-spacing:0.6px;
  color:var(--cyan);margin-bottom:10px;font-weight:600;
}
.row{display:flex;gap:10px;flex-wrap:wrap;}
.static-field{
  background:var(--navy3);border:1px solid var(--border);border-radius:8px;
  padding:12px;color:var(--muted);font-size:14px;
}

/* ---------- Selectable groups ---------- */
.opt-group{display:flex;flex-direction:column;gap:8px;}
.opt-btn{
  background:var(--navy3);border:1px solid var(--border);color:var(--text);
  border-radius:9px;padding:12px 14px;text-align:left;font-size:15px;
  cursor:pointer;font-family:'Barlow',sans-serif;
  display:flex;align-items:center;justify-content:space-between;
}
.opt-btn.selected{border-color:var(--cyan);background:rgba(50,204,254,0.12);color:var(--cyan);font-weight:600;}
.opt-btn .tick{opacity:0;color:var(--cyan);}
.opt-btn.selected .tick{opacity:1;}

.chip-row{display:flex;gap:8px;flex-wrap:wrap;}
.chip{
  background:var(--navy3);border:1px solid var(--border);color:var(--text);
  border-radius:20px;padding:9px 16px;font-size:14px;cursor:pointer;
  font-family:'Barlow Condensed',sans-serif;font-weight:600;
}
.chip.selected{background:var(--cyan);color:#05202b;border-color:var(--cyan);}

.speed-grid{display:grid;grid-template-columns:repeat(6,1fr);gap:8px;}
.speed-dial{
  aspect-ratio:1;width:100%;padding:0;
  border-radius:50%;
  background:var(--navy3);border:1px solid var(--border);color:var(--text);
  display:flex;align-items:center;justify-content:center;
  font-family:'Barlow Condensed',sans-serif;font-weight:700;font-size:16px;
  cursor:pointer;
}
.speed-dial.selected{background:var(--cyan);color:#05202b;border-color:var(--cyan);box-shadow:0 0 0 3px rgba(50,204,254,0.18);}
.speed-unit{text-align:center;color:var(--muted);font-size:11.5px;margin-top:8px;letter-spacing:0.4px;text-transform:uppercase;}

.toggle-row{display:flex;border:1px solid var(--border);border-radius:9px;overflow:hidden;}
.toggle-row button{
  flex:1;background:var(--navy3);color:var(--muted);border:none;
  padding:11px 8px;font-size:13.5px;cursor:pointer;font-family:'Barlow',sans-serif;
  border-right:1px solid var(--border);
}
.toggle-row button:last-child{border-right:none;}
.toggle-row button.selected{background:var(--cyan);color:#05202b;font-weight:600;}

.check-row{display:flex;align-items:center;gap:10px;padding:4px 0;}
.check-row input[type=checkbox]{width:20px;height:20px;accent-color:var(--cyan);}
.check-row label{font-size:14px;color:var(--text);}

.warning-banner{
  background:rgba(255,93,93,0.12);border:1px solid var(--red);
  color:#ffb3b3;border-radius:9px;padding:12px 14px;font-size:13.5px;
  margin-bottom:14px;display:flex;gap:8px;align-items:flex-start;
}
.warning-banner b{color:var(--red);}

.info-banner{
  background:rgba(255,181,71,0.1);border:1px solid var(--amber);
  color:var(--amber);border-radius:9px;padding:12px 14px;font-size:13.5px;
  margin-bottom:14px;
}

/* ---------- Bottom nav ---------- */
#bottom-nav{
  flex-shrink:0;
  background:var(--navy2);border-top:1px solid var(--border);
  display:flex;padding:6px 4px calc(6px + env(safe-area-inset-bottom));
}
.nav-btn{
  flex:1;background:none;border:none;color:var(--muted);
  display:flex;flex-direction:column;align-items:center;gap:3px;
  padding:8px 2px;cursor:pointer;font-family:'Barlow Condensed',sans-serif;
  font-size:12px;font-weight:600;letter-spacing:0.3px;
}
.nav-btn .ic{font-size:19px;line-height:1;}
.nav-btn.active{color:var(--cyan);}

/* Action bar: persistent primary-action strip between the scrollable content and the bottom nav.
   Always on screen without scrolling, on whichever screen it belongs to. */
.action-bar{
  flex-shrink:0;display:none;
  padding:12px 16px;background:var(--navy1);border-top:1px solid var(--border);
}
.action-bar.active{display:block;}

/* ---------- Guide screen ---------- */
.guide-category{margin-bottom:16px;}
.guide-category h3{
  font-size:16px;color:var(--cyan);margin-bottom:8px;
  display:flex;align-items:center;gap:8px;
}
.guide-item{
  display:flex;gap:10px;align-items:flex-start;
  background:var(--navy2);border:1px solid var(--border);
  border-radius:9px;padding:11px 12px;margin-bottom:7px;font-size:14px;
}
.guide-item input[type=checkbox]{margin-top:2px;width:19px;height:19px;flex-shrink:0;accent-color:var(--cyan);}
.guide-item.checked{opacity:0.5;text-decoration:line-through;}
.guide-item .gi-dist{color:var(--cyan);font-weight:600;white-space:nowrap;font-family:'Barlow Condensed',sans-serif;}

/* ---------- Diagram ---------- */
.diagram-toggle{display:flex;gap:8px;margin-bottom:10px;}
.diagram-wrap{
  background:var(--navy2);border:1px solid var(--border);border-radius:var(--radius);
  padding:10px;overflow:hidden;
}
.diagram-wrap svg{width:100%;height:auto;display:block;}
.legend{display:flex;flex-wrap:wrap;gap:8px 14px;margin-top:10px;font-size:12px;color:var(--muted);}
.legend span{display:inline-flex;align-items:center;gap:5px;}
.legend i{width:10px;height:10px;border-radius:2px;display:inline-block;}

/* ---------- Walk-out ---------- */
.walkout-hero{
  background:var(--navy2);border:1px solid var(--cyan-dim);border-radius:var(--radius);
  padding:20px;text-align:center;margin-bottom:14px;
}
.walkout-hero .sign-name{font-size:22px;color:var(--cyan);font-family:'Barlow Condensed',sans-serif;font-weight:700;}
.walkout-hero .dist-num{font-size:52px;font-weight:700;font-family:'Barlow Condensed',sans-serif;margin:8px 0;}
.walkout-hero .dist-unit{color:var(--muted);font-size:14px;}
.walkout-hero .arrow{font-size:30px;color:var(--cyan);margin:4px 0;}
.manual-btns{display:grid;grid-template-columns:repeat(4,1fr);gap:8px;margin-bottom:12px;}
.manual-btns button{
  background:var(--navy3);border:1px solid var(--border);color:var(--text);
  border-radius:8px;padding:10px 4px;font-size:13px;cursor:pointer;font-family:'Barlow Condensed',sans-serif;font-weight:600;
}
.progress-track{
  background:var(--navy3);border-radius:6px;height:10px;overflow:hidden;margin-bottom:6px;
}
.progress-fill{background:var(--cyan);height:100%;transition:width .3s;}
.progress-label{font-size:12px;color:var(--muted);text-align:center;margin-bottom:14px;}
.act-row{display:flex;gap:10px;}
.gps-status{font-size:12px;color:var(--muted);text-align:center;margin-bottom:10px;}
.gps-status.live{color:var(--green);}
.gps-status.stale{color:var(--amber);}

/* ---------- Site record ---------- */
.photo-grid{display:grid;grid-template-columns:repeat(4,1fr);gap:8px;margin-top:8px;}
.photo-slot{
  aspect-ratio:1;background:var(--navy3);border:1px dashed var(--border);
  border-radius:8px;display:flex;align-items:center;justify-content:center;
  font-size:22px;color:var(--muted);cursor:pointer;overflow:hidden;position:relative;
}
.photo-slot img{width:100%;height:100%;object-fit:cover;}
.photo-slot .rm{
  position:absolute;top:2px;right:2px;background:rgba(0,0,0,0.6);color:#fff;
  border:none;border-radius:50%;width:18px;height:18px;font-size:11px;cursor:pointer;
}

/* ---------- Reference ---------- */
.ref-table{width:100%;border-collapse:collapse;font-size:13.5px;margin-bottom:6px;}
.ref-table th,.ref-table td{
  border:1px solid var(--border);padding:8px 6px;text-align:center;
}
.ref-table th{background:var(--navy3);color:var(--cyan);font-family:'Barlow Condensed',sans-serif;font-weight:600;}
.ref-nav{display:flex;gap:6px;overflow-x:auto;margin-bottom:14px;padding-bottom:4px;}
.ref-nav button{
  flex-shrink:0;background:var(--navy3);border:1px solid var(--border);color:var(--muted);
  border-radius:16px;padding:7px 14px;font-size:13px;cursor:pointer;font-family:'Barlow Condensed',sans-serif;font-weight:600;
}
.ref-nav button.selected{background:var(--cyan);color:#05202b;border-color:var(--cyan);}
.ref-panel{display:none;}
.ref-panel.active{display:block;}
.sign-ref{
  background:var(--navy2);border:1px solid var(--border);border-radius:9px;
  padding:12px;margin-bottom:8px;font-size:13.5px;
}
.sign-ref b{color:var(--cyan);display:block;margin-bottom:3px;font-family:'Barlow Condensed',sans-serif;font-size:15px;}

/* ---------- Admin ---------- */
#admin-panel table{width:100%;font-size:13px;border-collapse:collapse;}
#admin-panel td,#admin-panel th{padding:6px 4px;border-bottom:1px solid var(--border);text-align:left;}

.spacer-sm{height:8px;}
.spacer{height:16px;}
.muted{color:var(--muted);}
.center{text-align:center;}
</style>
<div id="top-bar">
  <div class="brand">ConesOut<span style="font-size:11px;vertical-align:top;">&reg;</span></div>
  <div class="user-chip">
    <div id="user-display">-</div>
    <button type="button" id="logout-btn">Log out</button>
  </div>
</div>

<div id="screen-container">

<!-- ================= HOME ================= -->
