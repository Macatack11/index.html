<script>
/* ============================================================
   DISTANCES TABLE
   Source: Traffic Signs Manual Chapter 8 (2009), Part 2: Operations,
   Appendix Table A1.1 (Location and number of approach signs) and
   Table A1.3 (Recommended spacing and sizes of traffic cones).
   Values below are the STANDARD-scheme figures for each category
   (relaxation-scheme figures are lower and are not modelled here).
   Distances given as ranges in the source are stored as {min,max};
   the app uses the max (safer/more conservative) value for on-screen
   distances and for Walk-Out segment lengths.
============================================================ */
var TM_TABLE = {
  single30: {
    label: "Single carriageway, 30mph or less",
    sitingMin: 20, sitingMax: 45, clearVis: 60, signSize: 600,
    endMin: 10, endMax: 30,
    taper: 50, coneCount: 8, coneSize: 450, taperSpacing: 3, longSpacing: 9, warnLight: 9
  },
  single40: {
    label: "Single carriageway, 40mph",
    sitingMin: 45, sitingMax: 110, clearVis: 60, signSize: 750,
    endMin: 30, endMax: 45,
    taper: 80, coneCount: 28, coneSize: 450, taperSpacing: 3, longSpacing: 9, warnLight: 9
  },
  single50plus: {
    label: "Single carriageway, 50mph or more",
    sitingMin: 275, sitingMax: 450, clearVis: "75m at 50mph / 90m at 60mph", signSize: 900,
    endMin: 30, endMax: 45,
    taper: 100, coneCount: 68, coneSize: 750, taperSpacing: 1.5, longSpacing: 9, warnLight: 9
  },
  dual40: {
    label: "Dual carriageway, 40mph or less",
    siting: 300, clearVis: 60, signSize: 750, end: 45,
    taper: 100, coneCount: 35, coneSize: 450, taperSpacing: 3, longSpacing: 9, warnLight: 9
  },
  dual50: {
    label: "Dual carriageway, 50mph",
    siting: 800, sitingCongestionNote: "1 mile where congestion is likely",
    clearVis: 75, signSize: 1200, end: 90,
    taper: 150, coneCount: 101, coneSize: 750, taperSpacing: 1.5, longSpacing: 9, warnLight: 9
  },
  dual60: {
    label: "Dual carriageway, 60mph",
    siting: 1609, sitingLabel: "1 mile", sitingCongestionNote: "2 miles where congestion is likely",
    clearVis: 90, signSize: 1500, end: 90,
    taper: 150, coneCount: 101, coneSize: 750, taperSpacing: 1.5, longSpacing: 9, warnLight: 9
  },
  dualNational: {
    label: "Dual carriageway / motorway, national speed limit (70mph)",
    siting: 3219, sitingLabel: "2 miles", sitingCongestionNote: "3 miles where congestion is likely",
    clearVis: 120, signSize: 1500, end: 90,
    taper: 200, coneCount: 135, coneSize: 1000, taperSpacing: 1.5, longSpacing: 9, warnLight: 9
  }
};

// Maps the app's Home-screen selections onto the Table A1.1 / A1.3 category above.
function getTMCategory(h){
  var speed = Number(h.speed); // defensive: strict-equality checks below need a real Number
  if(h.roadType === "dual"){
    if(speed <= 40) return TM_TABLE.dual40;
    if(speed === 50) return TM_TABLE.dual50;
    if(speed === 60) return TM_TABLE.dual60;
    return TM_TABLE.dualNational; // 70mph
  }
  if(h.roadType === "motorway"){
    return TM_TABLE.dualNational; // motorways carry the national speed limit
  }
  // urban / rural = single carriageway
  if(speed <= 30) return TM_TABLE.single30;
  if(speed === 40) return TM_TABLE.single40;
  return TM_TABLE.single50plus; // 50/60/70mph on a single carriageway
}

function tmSitingDistance(cat){
  // Returns the recommended (upper/safer) siting distance as a plain number of metres for on-screen use.
  if(cat.sitingMax !== undefined) return cat.sitingMax;
  return cat.siting;
}
function tmSitingLabel(cat){
  if(cat.sitingLabel) return cat.sitingLabel;
  return tmSitingDistance(cat) + "m";
}
function tmEndDistance(cat){
  if(cat.endMax !== undefined) return cat.endMax;
  return cat.end;
}

var ROAD_LABELS = { urban:"Urban / Residential", rural:"Rural Single Carriageway", dual:"Dual Carriageway", motorway:"Motorway" };
var IMPACT_LABELS = { half:"Half Road", full:"Full Closure", footpath:"Footpath Only" };

/* ============================================================
   HOME SCREEN — selection handling
============================================================ */
function initHomeGroup(groupId, stateKey, activeClass){
  var group = qs("#" + groupId);
  if(!group) return;
  qsa("button", group).forEach(function(btn){
    on(btn, "click", function(){
      qsa("button", group).forEach(function(b){ b.classList.remove(activeClass); });
      btn.classList.add(activeClass);
      var raw = btn.getAttribute("data-value");
      // "speed" is compared with strict equality (===) elsewhere in getTMCategory(),
      // so it must be stored as a real Number, not the string data-value attribute gives us.
      STATE.home[stateKey] = (stateKey === "speed") ? Number(raw) : raw;
      refreshGenerateButton();
    });
  });
}

function refreshGenerateButton(){
  var h = STATE.home;
  var complete = h.roadType && h.speed && h.duration && h.impact;
  qs("#generate-btn").disabled = !complete;
}

function initHomeScreen(){
  initHomeGroup("group-roadtype", "roadType", "selected");
  initHomeGroup("group-speed", "speed", "selected");
  initHomeGroup("group-duration", "duration", "selected");
  initHomeGroup("group-impact", "impact", "selected");

  on(qs("#generate-btn"), "click", function(){
    try{
      STATE.guide = buildGuideSteps(STATE.home);
      renderGuideSummary();
      renderGuideChecklist(STATE.guide);
      buildWalkoutSigns();
      show(qs("#guide-content"));
      hide(qs("#guide-empty"));
      show(qs("#setup-content"));
      hide(qs("#setup-empty"));
      switchScreen("screen-guide");
    }catch(err){
      console.error("Generate Guide failed:", err);
      alert("Something went wrong generating the guide: " + (err && err.message ? err.message : err) + "\n\nPlease use the thumbs-down button to report this.");
    }
  });
}

/* ============================================================
   GUIDE GENERATION
============================================================ */
function buildGuideSteps(h){
  var cat = getTMCategory(h);
  var cats = [];

  // 1. Pre-works checks (CoP 2013 p.12-14 + Chapter 8 Part 2 O3.6.1/O6.3)
  var preItems = [
    { text:"Confirm permit / Section 50 licence covers this location and date." },
    { text:"Full hi-vis PPE worn by all crew — BS EN ISO 20471 Class 2, or Class 3 on motorways / other high-speed roads." },
    { text:"Load sufficient signs, cones, barriers and sandbags for ballasting." },
    { text:"Check for nearby schools — note peak times 8-9am and 3-4pm if applicable." },
    { text:"Assess parked cars and street obstructions before setting out — note any issues in the Site Record." },
    { text:"Works vehicle: amber beacon on, parked nearside, crew exit on passenger side only." },
    { text:"Maintain minimum lateral safety clearance between the works and the live carriageway.", dist: (h.speed >= 50 ? "1.2m" : "0.5m") }
  ];
  if(h.duration === "short"){
    preItems.push({ text:"Reduced signing (beacon only, no advance signs) is only permitted where ALL apply: permanent limit \u226430mph, two-way flow <400 veh/hr, <20 HGVs/hr, and the beacon is visible for 50m on each approach. Otherwise full signing is required even for short stops." });
  }
  cats.push({ title:"Pre-Works Checks", items:preItems });

  // 2. Advance warning
  var warnItems = [
    { text:"Position \"Road Works Ahead\" sign at the advance siting distance for this road category.", dist: tmSitingLabel(cat) },
    { text:"Confirm clear visibility of the sign from approaching traffic.", dist: cat.clearVis + (typeof cat.clearVis === "number" ? "m" : "") }
  ];
  if(h.roadType !== "motorway"){
    warnItems.push({ text:"Position speed roundel sign if the temporary speed limit is reduced from the permanent limit." });
  }
  if(cat.sitingCongestionNote){
    warnItems.push({ text:"Where congestion on approach is likely, increase the siting distance further.", dist: cat.sitingCongestionNote });
  }
  cats.push({ title:"Advance Warning Signing", items:warnItems });

  // 3. Lead-in taper
  cats.push({ title:"Lead-In Taper", items:[
    { text:"Position \"Road Narrows\" (both-sides) sign ahead of the taper." },
    { text:"Run the cone taper at the standard length for this road category.", dist: cat.taper + "m" },
    { text:"Minimum number of cones through the taper.", dist: String(cat.coneCount) },
    { text:"Minimum cone height for this road category.", dist: cat.coneSize + "mm" },
    { text:"Maximum cone spacing within the taper.", dist: cat.taperSpacing + "m" },
    { text:"Ballast all cones and freestanding signs with sandbags, particularly in wind." },
    { text:"Setting out starts with the advance \"Road Works Ahead\" sign, then works inward toward the site — sign the site in the sequence you'll walk it." }
  ]});

  // 4. Impact-specific
  if(h.impact === "half"){
    cats.push({ title:"Half Road Closure", items:[
      { text:"Position Keep Right / Keep Left sign with the arrow pointing AWAY from the works, into the open lane.", dist: cat.signSize + "mm" },
      { text:"Install barriers along the works boundary." },
      { text:"Maintain longitudinal clearance between the taper and the works area.", dist: cat.taper + "m" }
    ]});
  } else if(h.impact === "full"){
    cats.push({ title:"Full Closure", items:[
      { text:"Position \"Road Closed Ahead\" signs at both ends of the closure.", dist: cat.signSize + "mm" },
      { text:"Run a cone taper at both ends of the closure." },
      { text:"Install kerb-to-kerb barriers across the full closed section." },
      { text:"Sign an approved diversion route for the duration of the closure." },
      { text:"Maintain a buffer zone between the taper and the closed works area." }
    ]});
  } else if(h.impact === "footpath"){
    cats.push({ title:"Footpath Only", items:[
      { text:"Install continuous barriers around the full extent of the works — traffic cones alone are not an acceptable pedestrian barrier." },
      { text:"Maintain temporary pedestrian route width — 1.5m preferred, 1.2m minimum, 1.0m absolute minimum in exceptional circumstances only.", dist:"1.0-1.5m" },
      { text:"Sign a pedestrian diversion route if the footpath cannot be safely passed." }
    ]});
  }

  // 5. Temporary traffic signals note
  cats.push({ title:"Temporary Traffic Signals", items:[
    { text:"If temporary traffic signals are required for this site, do not install without approval — refer to manager and the Chapter 8 reference guide." }
  ]});

  // 6. Site conditions — considerations to check on site, not pre-declared on Home
  cats.push({ title:"Site Conditions — Check Before Setting Out", items:[
    { text:"Is the road on a bend or does it have restricted / dangerous sight lines? If so, refer to manager and see Chapter 8 Reference Guide before proceeding — standard distances above may not be sufficient." },
    { text:"Will works continue into darkness? If so: fit amber warning lights to cones/barriers along the taper.", dist: cat.warnLight + "m spacing" },
    { text:"Night-time: check local lighting-up times before finishing setup." },
    { text:"Night-time: if the site will be left unattended overnight, confirm illuminated warning lamps remain in place and functioning." }
  ]});

  // 7. Final items
  cats.push({ title:"Information & Closeout", items:[
    { text:"Position information board showing contractor name, purpose of works and contact number." },
    { text:"Walk the full length of the site to confirm every sign, cone and barrier is correctly placed." },
    { text:"Complete the Site Record — crew, permit reference, GPS location and photographs." },
    { text:"Removal is the reverse of setup: take down the End of Works sign first and work back out, removing the Road Works Ahead sign LAST for maximum protection while the crew is on site." }
  ]});

  return { categories: cats, category: cat };
}

function renderGuideSummary(){
  var h = STATE.home;
  var parts = [
    ROAD_LABELS[h.roadType], h.speed + " mph",
