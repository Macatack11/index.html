<script>
/* ============================================================
   VISUAL LAYOUT DIAGRAM (schematic, not to scale)
============================================================ */
var SZ = 34; // unified sign size, keep consistent across all sign icons

function svgSign(x, y, label, kind, rotateDeg){
  // kind: warn (triangle), round (circle), info (rounded rect)
  var half = SZ/2;
  var shape = "";
  if(kind === "warn"){
    shape = '<polygon points="' + x + ',' + (y-half) + ' ' + (x+half) + ',' + (y+half) + ' ' + (x-half) + ',' + (y+half) + '" fill="#111827" stroke="#ff5d5d" stroke-width="2.5"/>';
  } else if(kind === "round"){
    shape = '<circle cx="' + x + '" cy="' + y + '" r="' + half + '" fill="#111827" stroke="#32CCFE" stroke-width="2.5"/>';
    if(rotateDeg !== undefined){
      shape += '<g transform="translate(' + x + ',' + y + ') rotate(' + rotateDeg + ')"><path d="M -9 0 L 6 0 M 6 0 L 0 -6 M 6 0 L 0 6" stroke="#32CCFE" stroke-width="2.5" fill="none" stroke-linecap="round"/></g>';
    }
  } else if(kind === "closed"){
    shape = '<rect x="' + (x-half) + '" y="' + (y-half) + '" width="' + SZ + '" height="' + SZ + '" rx="4" fill="#111827" stroke="#ff5d5d" stroke-width="2.5"/>';
  } else {
    shape = '<rect x="' + (x-half) + '" y="' + (y-half) + '" width="' + SZ + '" height="' + SZ + '" rx="4" fill="#111827" stroke="#8fa3bd" stroke-width="2"/>';
  }
  return shape;
}

function svgLabel(x, y, text, anchor){
  return '<text x="' + x + '" y="' + y + '" font-size="9.5" fill="#8fa3bd" text-anchor="' + (anchor||"middle") + '" font-family="Barlow, sans-serif">' + text + '</text>';
}

function renderDiagram(state, orientation){
  var h = state;
  var portrait = orientation === "0";
  var W = portrait ? 320 : 560;
  var H = portrait ? 560 : 320;
  var axisLen = portrait ? H : W;      // length along travel direction
  var roadCx = portrait ? W/2 : H/2;   // road centre on cross axis
  var roadWidth = 70;

  // fractional positions along the axis (0 = far/approach, 1 = near/end)
  var pWarn = 0.08, pRoundel = 0.16, pNarrows = 0.25, pTaperStart = 0.31,
      pTaperEnd = 0.47, pWorksStart = 0.47, pWorksEnd = h.impact === "full" ? 0.68 : 0.73,
      pClosedSign = 0.70, pEndSign = 0.87;

  function axisPos(frac){ return 20 + frac * (axisLen - 40); }
  function pt(frac, offset){
    var a = axisPos(frac);
    if(portrait){ return { x: roadCx + offset, y: a }; }
    return { x: a, y: roadCx + offset };
  }

  var svg = "";
  var signOffset = roadWidth/2 + SZ/2 + 14; // consistent distance of signs from carriageway edge

  // Road surface
  if(portrait){
    svg += '<rect x="' + (roadCx-roadWidth/2) + '" y="0" width="' + roadWidth + '" height="' + H + '" fill="#1a2a42" stroke="#2a3d5c"/>';
    svg += '<line x1="' + roadCx + '" y1="0" x2="' + roadCx + '" y2="' + H + '" stroke="#3d5273" stroke-width="2" stroke-dasharray="10 8"/>';
  } else {
    svg += '<rect x="0" y="' + (roadCx-roadWidth/2) + '" width="' + W + '" height="' + roadWidth + '" fill="#1a2a42" stroke="#2a3d5c"/>';
    svg += '<line x1="0" y1="' + roadCx + '" x2="' + W + '" y2="' + roadCx + '" stroke="#3d5273" stroke-width="2" stroke-dasharray="10 8"/>';
  }

  // Direction arrow (travel direction = increasing frac)
  var da = pt(0.02, 0);
  svg += svgLabel(da.x, da.y - (portrait?0:0), portrait ? "TRAFFIC" : "", "middle");

  // Advance warning sign
  var p1 = pt(pWarn, signOffset);
  svg += svgSign(p1.x, p1.y, "", "warn");
  svg += svgLabel(p1.x, p1.y + SZ/2 + 12, "Road Works Ahead");
  svg += svgLabel(p1.x, p1.y + SZ/2 + 23, tmSitingLabel(getTMCategory(h)), "middle");

  // Speed roundel
  if(h.roadType !== "motorway"){
    var p2 = pt(pRoundel, signOffset);
    svg += svgSign(p2.x, p2.y, "", "round");
    svg += svgLabel(p2.x, p2.y + SZ/2 + 12, h.speed + " mph");
  }

  // Road narrows
  var p3 = pt(pNarrows, signOffset);
  svg += svgSign(p3.x, p3.y, "", "warn");
  svg += svgLabel(p3.x, p3.y + SZ/2 + 12, "Narrows");

  // Taper cones
  var coneCount = 7;
  for(var i=0;i<=coneCount;i++){
    var frac = pTaperStart + (pTaperEnd - pTaperStart) * (i/coneCount);
    var lateral = (roadWidth/2 - 4) * (1 - i/coneCount) + 4; // converge toward centre-ish edge
    var cp = pt(frac, lateral);
    svg += '<circle cx="' + cp.x + '" cy="' + cp.y + '" r="4" fill="#ffb547"/>';
  }
  var tlabel = pt((pTaperStart+pTaperEnd)/2, roadWidth/2 + 28);
  svg += svgLabel(tlabel.x, tlabel.y, "Taper " + getTMCategory(h).taper + "m");

  // Impact-specific
  if(h.impact === "half"){
    var p4 = pt(pWorksStart + 0.02, signOffset);
    svg += svgSign(p4.x, p4.y, "", "round", 0);
    svg += svgLabel(p4.x, p4.y + SZ/2 + 12, "Keep Right");
    svg += svgLabel(p4.x, p4.y + SZ/2 + 23, "(arrow away from works)");
    // barrier line along the closed half
    var b1 = pt(pWorksStart, -roadWidth/2+6);
    var b2 = pt(pWorksEnd, -roadWidth/2+6);
    if(portrait){
      svg += '<line x1="' + b1.x + '" y1="' + b1.y + '" x2="' + b2.x + '" y2="' + b2.y + '" stroke="#ff5d5d" stroke-width="4"/>';
    } else {
      svg += '<line x1="' + b1.x + '" y1="' + b1.y + '" x2="' + b2.x + '" y2="' + b2.y + '" stroke="#ff5d5d" stroke-width="4"/>';
    }
  } else if(h.impact === "full"){
    var p5 = pt(pClosedSign, signOffset);
    svg += svgSign(p5.x, p5.y, "", "closed");
    svg += svgLabel(p5.x, p5.y + SZ/2 + 12, "Road Closed");
    // kerb to kerb barrier
    var kb1 = pt(pWorksStart, -roadWidth/2+2);
    var kb2 = pt(pWorksStart, roadWidth/2-2);
    svg += '<line x1="' + kb1.x + '" y1="' + kb1.y + '" x2="' + kb2.x + '" y2="' + kb2.y + '" stroke="#ff5d5d" stroke-width="4"/>';
  } else if(h.impact === "footpath"){
    var fb1 = pt(pWorksStart, roadWidth/2 - 2);
    var fb2 = pt(pWorksEnd, roadWidth/2 - 2);
    svg += '<line x1="' + fb1.x + '" y1="' + fb1.y + '" x2="' + fb2.x + '" y2="' + fb2.y + '" stroke="#ff5d5d" stroke-width="4"/>';
    var fl = pt((pWorksStart+pWorksEnd)/2, roadWidth/2 + 18);
    svg += svgLabel(fl.x, fl.y, "Min. 1.0m pedestrian clearance");
  }

  // works zone + vehicle
  var wz1 = pt(pWorksStart, 0);
  var wz2 = pt(pWorksEnd, 0);
  var wzLen = Math.abs(portrait ? (wz2.y-wz1.y) : (wz2.x-wz1.x));
  if(portrait){
    svg += '<rect x="' + (roadCx-roadWidth/2+6) + '" y="' + wz1.y + '" width="' + (roadWidth-12) + '" height="' + wzLen + '" fill="rgba(50,204,254,0.14)" stroke="#32CCFE" stroke-dasharray="4 3"/>';
    svg += '<rect x="' + (roadCx-14) + '" y="' + (wz1.y + wzLen/2 - 10) + '" width="28" height="20" rx="3" fill="#32CCFE"/>';
  } else {
    svg += '<rect x="' + wz1.x + '" y="' + (roadCx-roadWidth/2+6) + '" width="' + wzLen + '" height="' + (roadWidth-12) + '" fill="rgba(50,204,254,0.14)" stroke="#32CCFE" stroke-dasharray="4 3"/>';
    svg += '<rect x="' + (wz1.x + wzLen/2 - 14) + '" y="' + (roadCx-10) + '" width="28" height="20" rx="3" fill="#32CCFE"/>';
  }
  var wl = pt((pWorksStart+pWorksEnd)/2, roadWidth/2 + (h.impact==="footpath"?32:28));
  svg += svgLabel(wl.x, wl.y, "Works Zone");

  // end of works sign
  var p6 = pt(pEndSign, signOffset);
  svg += svgSign(p6.x, p6.y, "", "info");
  svg += svgLabel(p6.x, p6.y + SZ/2 + 12, "End of Works");

  var viewBox = "0 0 " + W + " " + H;
  return '<svg viewBox="' + viewBox + '" width="' + W + '" height="' + H + '" xmlns="http://www.w3.org/2000/svg" style="background:#0d1f35">' + svg + '</svg>';
}

function renderDiagramPanel(){
  var wrap = qs("#diagram-wrap");
  if(!wrap){ return; } // diagram card removed - superseded by layout.html
  try{
    wrap.innerHTML = renderDiagram(STATE.home, STATE.diagramOrient);
  }catch(err){
    wrap.innerHTML = '<div style="padding:16px;color:#ff5d5d;font-size:13px;">Diagram failed to render: ' +
      (err && err.message ? err.message.replace(/[<>&]/g, "") : "unknown error") +
      '. Please use the thumbs-down button to report this.</div>';
    return;
  }
  // Don't rely on CSS width:100%;height:auto to derive height from the SVG's viewBox
  // aspect ratio — compute it explicitly in pixels instead, same reasoning as the
  // screen-container height fix: don't depend on automatic sizing behaving as spec'd
  // if it can just be computed directly.
  var svgEl = wrap.querySelector("svg");
  if(svgEl){
    var vb = (svgEl.getAttribute("viewBox") || "").split(/\s+/).map(Number);
    if(vb.length === 4 && vb[2] > 0){
      var wrapWidth = wrap.getBoundingClientRect().width || wrap.clientWidth;
      var innerWidth = Math.max(wrapWidth - 20, 100); // minus .diagram-wrap's own padding
      var aspect = vb[3] / vb[2];
      svgEl.style.width = innerWidth + "px";
      svgEl.style.height = Math.round(innerWidth * aspect) + "px";
      svgEl.style.display = "block";
    }
  }
  var legend = qs("#diagram-legend");
  if(!legend){ return; }
  legend.innerHTML =
    '<span><i style="background:#ff5d5d"></i>Warning / closure sign</span>' +
    '<span><i style="background:#32CCFE"></i>Works zone / vehicle</span>' +
    '<span><i style="background:#ffb547"></i>Cone taper</span>';
}

function initDiagramToggle(){
  qsa(".diagram-toggle .chip").forEach(function(btn){
    on(btn, "click", function(){
      qsa(".diagram-toggle .chip").forEach(function(b){ b.classList.remove("selected"); });
      btn.classList.add("selected");
      STATE.diagramOrient = btn.getAttribute("data-orient");
      renderDiagramPanel();
    });
  });
}

window.renderDiagram = renderDiagram;
window.renderDiagramPanel = renderDiagramPanel;
window.initDiagramToggle = initDiagramToggle;
</script>
<script>
/* ============================================================
   WALK-OUT MODE
============================================================ */
var GPS_NOISE_THRESHOLD_M = 2;   // ignore movement smaller than this (GPS jitter)
var GPS_MAX_ACCURACY_M = 25;     // ignore fixes worse than this

function haversineMeters(lat1, lon1, lat2, lon2){
  var R = 6371000;
  var toRad = function(d){ return d * Math.PI / 180; };
  var dLat = toRad(lat2-lat1);
  var dLon = toRad(lon2-lon1);
  var a = Math.sin(dLat/2)*Math.sin(dLat/2) +
          Math.cos(toRad(lat1))*Math.cos(toRad(lat2))*Math.sin(dLon/2)*Math.sin(dLon/2);
  var c = 2*Math.atan2(Math.sqrt(a), Math.sqrt(1-a));
  return R*c;
}

function buildWalkoutSigns(){
  var h = STATE.home;
  var cat = getTMCategory(h);
  var siting = tmSitingDistance(cat);
  var list = [];
  list.push({ name:"Road Works Ahead", segment: siting });
  if(h.roadType !== "motorway"){
    list.push({ name:"Speed Roundel", segment: 15 });
  }
  list.push({ name:"Road Narrows", segment: 15 });
  list.push({ name:"Taper Cones — Start", segment: Math.max(cat.taper - 25, 10) });

  if(h.impact === "half"){
    list.push({ name:"Keep Right / Keep Left Sign", segment: 25 });
  } else if(h.impact === "full"){
    list.push({ name:"Road Closed Sign", segment: 25 });
  } else if(h.impact === "footpath"){
    list.push({ name:"Barrier Start", segment: 20 });
  }

  list.push({ name:"Information Board", segment: 5 });
  list.push({ name:"End of Works Sign", segment: tmEndDistance(cat) });

  STATE.walkout.signs = list;
  STATE.walkout.index = 0;
  STATE.walkout.traveled = 0;
  updateWalkoutUI();
  startWalkoutWatch();
}

function currentWalkoutSign(){
  return STATE.walkout.signs[STATE.walkout.index] || null;
}

function updateWalkoutUI(){
  var total = STATE.walkout.signs.length;
  var idx = STATE.walkout.index;
  var sign = currentWalkoutSign();

  if(!sign){
    qs("#wo-sign-name").textContent = "All signs placed";
    qs("#wo-distance").textContent = "0";
    qs("#wo-arrow").textContent = "\u2713";
    qs("#wo-progress-fill").style.width = "100%";
    qs("#wo-progress-label").textContent = total + " of " + total + " signs placed";
    return;
  }

  var remaining = Math.max(sign.segment - STATE.walkout.traveled, 0);
  qs("#wo-sign-name").textContent = sign.name;
  qs("#wo-distance").textContent = remaining < 1 ? remaining.toFixed(1) : Math.round(remaining);
  qs("#wo-arrow").textContent = remaining <= 0 ? "\u2713" : "\u2191";
  var pct = Math.round((idx / total) * 100);
  qs("#wo-progress-fill").style.width = pct + "%";
  qs("#wo-progress-label").textContent = idx + " of " + total + " signs placed";
}

function addWalkoutDistance(metres){
  if(!currentWalkoutSign()) return;
  STATE.walkout.traveled += metres;
  updateWalkoutUI();
}

function walkoutPlaced(){
  if(!currentWalkoutSign()) return;
  STATE.walkout.index += 1;
  STATE.walkout.traveled = 0;
  STATE.walkout.lastPos = null;
  updateWalkoutUI();
}

function walkoutSkip(){
  if(!currentWalkoutSign()) return;
  STATE.walkout.index += 1;
  STATE.walkout.traveled = 0;
  STATE.walkout.lastPos = null;
  updateWalkoutUI();
}

function walkoutReset(){
  STATE.walkout.index = 0;
  STATE.walkout.traveled = 0;
  STATE.walkout.lastPos = null;
  updateWalkoutUI();
}

function startWalkoutWatch(){
  if(!navigator.geolocation) {
    var s = qs("#gps-status");
    if(s){ s.textContent = "GPS not available on this device — use manual distance buttons."; s.className = "gps-status stale"; }
    return;
  }
  stopWalkoutWatch();
  try{
    STATE.walkout.watchId = navigator.geolocation.watchPosition(onWalkoutPosition, onWalkoutGpsError, {
      enableHighAccuracy: true,
      maximumAge: 2000,
      timeout: 10000
    });
  }catch(err){
    var s2 = qs("#gps-status");
    if(s2){ s2.textContent = "GPS unavailable in this browser context (e.g. requires https:// or localhost) — use manual distance buttons."; s2.className = "gps-status stale"; }
  }
}

function stopWalkoutWatch(){
  if(STATE.walkout.watchId !== null && navigator.geolocation){
    try{ navigator.geolocation.clearWatch(STATE.walkout.watchId); }catch(err){}
  }
  STATE.walkout.watchId = null;
}

function onWalkoutGpsError(){
  var s = qs("#gps-status");
  if(s){ s.textContent = "GPS signal unavailable — use manual distance buttons."; s.className = "gps-status stale"; }
}

function onWalkoutPosition(pos){
  var s = qs("#gps-status");
  var accuracy = pos.coords.accuracy;

  if(accuracy > GPS_MAX_ACCURACY_M){
    if(s){ s.textContent = "GPS signal weak (\u00b1" + Math.round(accuracy) + "m) — use manual buttons if needed."; s.className = "gps-status stale"; }
  } else {
    if(s){ s.textContent = "GPS live (\u00b1" + Math.round(accuracy) + "m)"; s.className = "gps-status live"; }
  }

  var last = STATE.walkout.lastPos;
  if(last){
    var delta = haversineMeters(last.lat, last.lon, pos.coords.latitude, pos.coords.longitude);
    // Only count movement above the GPS noise floor — a stationary operative must not see the distance tick down.
    if(delta >= GPS_NOISE_THRESHOLD_M && accuracy <= GPS_MAX_ACCURACY_M){
      addWalkoutDistance(delta);
      STATE.walkout.lastPos = { lat: pos.coords.latitude, lon: pos.coords.longitude };
    }
  } else {
    STATE.walkout.lastPos = { lat: pos.coords.latitude, lon: pos.coords.longitude };
  }
}

function initWalkoutScreen(){
  on(qs("#wo-placed-btn"), "click", walkoutPlaced);
  on(qs("#wo-skip-btn"), "click", walkoutSkip);
  on(qs("#wo-reset-btn"), "click", walkoutReset);
  qsa(".manual-btns button").forEach(function(btn){
    on(btn, "click", function(){
      addWalkoutDistance(parseFloat(btn.getAttribute("data-add")));
    });
  });
}

window.buildWalkoutSigns = buildWalkoutSigns;
window.initWalkoutScreen = initWalkoutScreen;
window.stopWalkoutWatch = stopWalkoutWatch;
</script>
<script>
/* ============================================================
   SITE RECORD
============================================================ */
var activePhotoSlot = null;

function initSiteRecord(){
  on(qs("#rec-crewlead"), "input", function(e){ STATE.record.crewLead = e.target.value; });
  on(qs("#rec-permit"), "input", function(e){ STATE.record.permit = e.target.value; });

  on(qs("#rec-capture-gps-btn"), "click", captureSiteGps);

  qsa(".photo-slot").forEach(function(slot){
    on(slot, "click", function(){
      var idx = parseInt(slot.getAttribute("data-slot"), 10);
      if(STATE.record.photos[idx]){ return; } // use the remove button instead
      activePhotoSlot = idx;
      qs("#photo-input").click();
    });
  });

  on(qs("#photo-input"), "change", function(e){
    var file = e.target.files && e.target.files[0];
    if(!file || activePhotoSlot === null) return;
    var reader = new FileReader();
    reader.onload = function(evt){
      STATE.record.photos[activePhotoSlot] = evt.target.result;
      renderPhotoGrid();
    };
    reader.readAsDataURL(file);
    e.target.value = "";
  });

  on(qs("#rec-generate-pdf-btn"), "click", generateSitePdf);
  renderPhotoGrid();
}

function captureSiteGps(){
  var display = qs("#rec-gps-display");
  if(!navigator.geolocation){
    display.textContent = "GPS not available in this browser context (e.g. requires https:// or localhost).";
    return;
  }
  display.textContent = "Capturing location...";
  try{
    navigator.geolocation.getCurrentPosition(function(pos){
      STATE.record.gps = {
        lat: pos.coords.latitude,
        lon: pos.coords.longitude,
        accuracy: pos.coords.accuracy,
        time: new Date().toISOString()
      };
      display.textContent = STATE.record.gps.lat.toFixed(6) + ", " + STATE.record.gps.lon.toFixed(6) + " (\u00b1" + Math.round(STATE.record.gps.accuracy) + "m)";
    }, function(){
      display.textContent = "Could not capture GPS location — check device location permissions.";
    }, { enableHighAccuracy:true, timeout:10000 });
  }catch(err){
    display.textContent = "GPS unavailable in this browser context (e.g. requires https:// or localhost).";
  }
}

function renderPhotoGrid(){
  qsa(".photo-slot").forEach(function(slot){
    var idx = parseInt(slot.getAttribute("data-slot"), 10);
    var data = STATE.record.photos[idx];
    slot.innerHTML = "";
    if(data){
      var img = document.createElement("img");
      img.src = data;
      slot.appendChild(img);
      var rm = document.createElement("button");
      rm.type = "button";
      rm.className = "rm";
      rm.textContent = "\u00d7";
      on(rm, "click", function(evt){
        evt.stopPropagation();
        STATE.record.photos[idx] = null;
        renderPhotoGrid();
      });
      slot.appendChild(rm);
    } else {
      slot.textContent = "+";
    }
  });
}

function getCompletedGuideItems(){
  var checked = qsa("#guide-checklist input[type=checkbox]:checked");
  return checked.map(function(cb){
    var span = cb.nextSibling;
    return span ? span.textContent : "";
  });
}

function generateSitePdf(){
  if(typeof window.jspdf === "undefined"){
    alert("PDF library failed to load — check your internet connection and try again.");
    return;
  }
  var jsPDF = window.jspdf.jsPDF;
  var doc = new jsPDF({ unit:"mm", format:"a4" });
  var y = 18;
  var left = 15;
  var pageWidth = 210;

  doc.setFont("helvetica", "bold");
  doc.setFontSize(18);
  doc.text("ConesOut Site Record", left, y);
  y += 9;

  doc.setFont("helvetica", "normal");
  doc.setFontSize(10);
  doc.text("Generated: " + new Date().toLocaleString(), left, y);
  y += 8;

  doc.setFont("helvetica", "bold");
  doc.setFontSize(12);
  doc.text("Crew & Job Details", left, y);
  y += 6;
  doc.setFont("helvetica", "normal");
  doc.setFontSize(10);
  doc.text("Crew Lead: " + (STATE.record.crewLead || "-"), left, y); y += 6;
  doc.text("Permit / Job Reference: " + (STATE.record.permit || "-"), left, y); y += 6;
  doc.text("Logged in as: " + (STATE.user ? STATE.user.username : "-"), left, y); y += 8;

  doc.setFont("helvetica", "bold");
  doc.setFontSize(12);
  doc.text("Site Setup", left, y);
  y += 6;
  doc.setFont("helvetica", "normal");
  doc.setFontSize(10);
  var h = STATE.home;
  doc.text("Road Type: " + (ROAD_LABELS[h.roadType] || "-"), left, y); y += 6;
  doc.text("Speed Limit: " + (h.speed || "-") + " mph", left, y); y += 6;
  doc.text("Duration: " + (h.duration === "short" ? "Under 15 min" : "Over 15 min"), left, y); y += 6;
  doc.text("Works Impact: " + (IMPACT_LABELS[h.impact] || "-"), left, y); y += 8;

  doc.setFont("helvetica", "bold");
  doc.setFontSize(12);
  doc.text("GPS Location", left, y);
  y += 6;
  doc.setFont("helvetica", "normal");
  doc.setFontSize(10);
  if(STATE.record.gps){
    doc.text(STATE.record.gps.lat.toFixed(6) + ", " + STATE.record.gps.lon.toFixed(6) + " (\u00b1" + Math.round(STATE.record.gps.accuracy) + "m)", left, y);
  } else {
    doc.text("Not captured", left, y);
  }
  y += 10;

  doc.setFont("helvetica", "bold");
  doc.setFontSize(12);
  doc.text("Steps Completed", left, y);
  y += 6;
  doc.setFont("helvetica", "normal");
  doc.setFontSize(9.5);
  var items = getCompletedGuideItems();
  if(items.length === 0){
    doc.text("No checklist items marked complete.", left, y);
    y += 6;
  } else {
    items.forEach(function(text){
      if(y > 275){ doc.addPage(); y = 18; }
      var lines = doc.splitTextToSize("- " + text, pageWidth - left*2);
      doc.text(lines, left, y);
      y += lines.length * 5;
    });
  }

  var photos = STATE.record.photos.filter(function(p){ return !!p; });
  if(photos.length){
    doc.addPage();
    y = 18;
    doc.setFont("helvetica", "bold");
    doc.setFontSize(12);
    doc.text("Site Photos", left, y);
    y += 8;
    var imgW = 85, imgH = 65, col = 0;
    photos.forEach(function(data){
      var x = left + col * (imgW + 8);
      try{ doc.addImage(data, "JPEG", x, y, imgW, imgH); }catch(e){}
      col++;
      if(col > 1){ col = 0; y += imgH + 8; }
    });
  }

  var filename = "conesout-site-record-" + Date.now() + ".pdf";
  try{
    doc.output("dataurlnewwindow");
  }catch(e){
    doc.save(filename);
  }
}

window.initSiteRecord = initSiteRecord;
</script>
