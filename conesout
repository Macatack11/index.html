  </div>
</div>
<!-- ================= SETUP (Walk-Out + Site Record) ================= -->
<div class="screen" id="screen-setup">

  <div id="setup-empty" class="card center muted">
    Generate a guide on the <b style="color:var(--cyan)">Home</b> screen first to unlock Walk-Out mode and the Site Record.
  </div>

  <div id="setup-content" class="hidden">

    <div class="ref-nav" id="setup-subnav">
      <button type="button" class="selected" data-panel="walkout">Walk-Out</button>
      <button type="button" data-panel="record">Site Record</button>
    </div>

    <!-- Walk-Out panel -->
    <div class="ref-panel active" id="panel-walkout">
      <div class="gps-status" id="gps-status">GPS: waiting for signal&hellip;</div>

      <div class="walkout-hero">
        <div class="sign-name" id="wo-sign-name">-</div>
        <div class="arrow" id="wo-arrow">&#8593;</div>
        <div class="dist-num" id="wo-distance">-</div>
        <div class="dist-unit">metres remaining</div>
      </div>

      <div class="manual-btns">
        <button type="button" data-add="1">+1m</button>
        <button type="button" data-add="5">+5m</button>
        <button type="button" data-add="10">+10m</button>
        <button type="button" data-add="25">+25m</button>
      </div>

      <div class="progress-track"><div class="progress-fill" id="wo-progress-fill" style="width:0%"></div></div>
      <div class="progress-label" id="wo-progress-label">0 of 0 signs placed</div>

      <div class="act-row">
        <button type="button" class="btn btn-secondary" id="wo-skip-btn">Skip</button>
        <button type="button" class="btn btn-primary" id="wo-placed-btn">Placed</button>
      </div>
      <div class="spacer-sm"></div>
      <button type="button" class="btn btn-ghost btn-sm" id="wo-reset-btn">Reset Walk-Out</button>
    </div>

    <!-- Site Record panel -->
