<div id="admin-overlay">
  <div class="admin-card">
    <h2>Manage Test Users</h2>
    <div id="admin-user-list"></div>
    <div class="spacer"></div>
    <div class="field">
      <label for="admin-new-username">New Username</label>
      <input type="text" id="admin-new-username">
    </div>
    <div class="field">
      <label for="admin-new-passcode">New Passcode</label>
      <input type="text" id="admin-new-passcode">
    </div>
    <div class="field">
      <label for="admin-new-role">Role</label>
      <select id="admin-new-role">
        <option value="Operative">Operative</option>
        <option value="Admin">Admin</option>
      </select>
    </div>
    <button type="button" class="btn btn-primary btn-sm" id="admin-add-btn">Add User</button>
    <div id="admin-status"></div>
    <div class="spacer"></div>
    <button type="button" class="btn btn-secondary" id="admin-close-btn">Close</button>
  </div>
</div>
<script>
/* ============================================================
   ADMIN PANEL (hidden feature — toggle via ADMIN_FEATURE_ENABLED)
============================================================ */
function supabaseHeaders(extra){
  var base = {
    "apikey": SUPABASE_ANON_KEY,
    "Authorization": "Bearer " + SUPABASE_ANON_KEY,
    "Content-Type": "application/json"
  };
  if(extra){ for(var k in extra){ base[k] = extra[k]; } }
  return base;
}

function loadAdminUsers(){
  var url = SUPABASE_URL + "/rest/v1/test_users?select=username,role&order=username";
  fetch(url, { headers: supabaseHeaders() })
    .then(function(res){ return res.json(); })
    .then(function(rows){ renderAdminUserList(rows || []); })
    .catch(function(){ qs("#admin-status").textContent = "Could not load user list."; });
}

function renderAdminUserList(rows){
  var list = qs("#admin-user-list");
  list.innerHTML = "";
  rows.forEach(function(u){
    var row = document.createElement("div");
    row.className = "admin-user-row";
    var label = document.createElement("span");
    label.textContent = u.username + " — " + (u.role || "Operative");
    var del = document.createElement("button");
    del.type = "button";
    del.textContent = "Remove";
    on(del, "click", function(){ deleteAdminUser(u.username); });
    row.appendChild(label);
    row.appendChild(del);
    list.appendChild(row);
  });
}

function deleteAdminUser(username){
  if(!confirm("Remove user \"" + username + "\"?")) return;
  var url = SUPABASE_URL + "/rest/v1/test_users?username=eq." + encodeURIComponent(username);
  fetch(url, { method:"DELETE", headers: supabaseHeaders() })
    .then(function(){ loadAdminUsers(); })
    .catch(function(){ qs("#admin-status").textContent = "Could not remove user."; });
}

function addAdminUser(){
  var username = qs("#admin-new-username").value.trim();
  var passcode = qs("#admin-new-passcode").value.trim();
  var role = qs("#admin-new-role").value;
  var status = qs("#admin-status");
  if(!username || !passcode){
    status.textContent = "Enter a username and passcode.";
    return;
  }
  var url = SUPABASE_URL + "/rest/v1/test_users";
  fetch(url, {
    method: "POST",
    headers: supabaseHeaders({ "Prefer": "return=minimal" }),
    body: JSON.stringify({ username: username, passcode: passcode, role: role })
  })
  .then(function(res){
    if(!res.ok) throw new Error();
    status.textContent = "User added.";
    qs("#admin-new-username").value = "";
    qs("#admin-new-passcode").value = "";
    loadAdminUsers();
  })
  .catch(function(){ status.textContent = "Could not add user — username may already exist."; });
}

function initAdminPanel(){
  if(!ADMIN_FEATURE_ENABLED) return;
  // Long-press the brand logo to open the admin panel when logged in as Admin.
  var brand = qs("#top-bar .brand");
  var pressTimer = null;
  on(brand, "touchstart", function(){ pressTimer = setTimeout(openAdminPanel, 900); });
  on(brand, "touchend", function(){ clearTimeout(pressTimer); });
  on(brand, "mousedown", function(){ pressTimer = setTimeout(openAdminPanel, 900); });
  on(brand, "mouseup", function(){ clearTimeout(pressTimer); });

  on(qs("#admin-close-btn"), "click", function(){ qs("#admin-overlay").classList.remove("open"); });
  on(qs("#admin-add-btn"), "click", addAdminUser);
}

function openAdminPanel(){
  if(!STATE.user || STATE.user.role !== "Admin") return;
  qs("#admin-overlay").classList.add("open");
  loadAdminUsers();
}

window.initAdminPanel = initAdminPanel;
</script>
<script>
document.addEventListener("DOMContentLoaded", function(){
  window.__conesout_init_auth_nav();
  initHomeScreen();
  initDiagramToggle();
  initWalkoutScreen();
  initSiteRecord();
  initAdminPanel();

  // Belt-and-braces: some emulated/DevTools viewport contexts compute dvh/vh unreliably.
  // Force #app-shell to the exact measured viewport height in pixels as a hard guarantee,
  // on top of (not instead of) the CSS height:100dvh rule.
  function pinAppShellHeight(){
    var shell = qs("#app-shell");
    if(shell) shell.style.height = window.innerHeight + "px";
  }

  // CRITICAL FIX: flex-shrink on #screen-container was not reliably engaging in some
  // browser contexts, letting it render at its full natural content height instead of
  // being squeezed to fit — which pushed the action bar and bottom nav off-screen even
  // though overflow:hidden was clipping them from view. Rather than depend on flexbox
  // shrink behavior, compute the available height directly and set it explicitly. This
  // cannot fail regardless of any flex-shrink quirk since it's pure arithmetic.
  function pinScreenContainerHeight(){
    var shell = qs("#app-shell");
    var topBar = qs("#top-bar");
    var actionBar = qs("#home-action-bar");
    var nav = qs("#bottom-nav");
    var container = qs("#screen-container");
    if(!shell || !topBar || !nav || !container) return;
    var shellH = shell.getBoundingClientRect().height || window.innerHeight;
    var topH = topBar.getBoundingClientRect().height;
    var actionH = (actionBar && actionBar.classList.contains("active")) ? actionBar.getBoundingClientRect().height : 0;
    var navH = nav.getBoundingClientRect().height;
    var available = shellH - topH - actionH - navH;
    container.style.height = Math.max(available, 100) + "px";
  }

  function pinLayout(){
    pinAppShellHeight();
    pinScreenContainerHeight();
  }
  pinLayout();
  window.addEventListener("resize", pinLayout);
  window.addEventListener("orientationchange", function(){ setTimeout(pinLayout, 250); });
  if(window.visualViewport){
    window.visualViewport.addEventListener("resize", pinLayout);
  }
  window.__conesout_pinLayout = pinLayout; // switchScreen calls this after toggling the action bar

  // Layout diagnostic panel: shows exact measured dimensions of every layout-critical
  // element directly on the page. Toggle by tapping the ConesOut logo 3 times fast.
  // This exists so layout bugs can be diagnosed from one screenshot, no DevTools needed.
  function showLayoutDiagnostics(){
    var ids = ["app-shell","top-bar","screen-container","home-action-bar","bottom-nav","generate-btn","screen-home","screen-guide","diagram-wrap","guide-checklist","guide-content","guide-empty"];
    var lines = ["viewport: " + window.innerWidth + "x" + window.innerHeight, ""];
    ids.forEach(function(id){
      var el = document.getElementById(id);
      if(!el){ lines.push(id + ": NOT FOUND"); return; }
      var r = el.getBoundingClientRect();
      var cs = window.getComputedStyle(el);
      var extra = " innerHTML.length=" + (el.innerHTML ? el.innerHTML.length : 0);
      lines.push(id + ": top=" + Math.round(r.top) + " bottom=" + Math.round(r.bottom) + " h=" + Math.round(r.height) + " display=" + cs.display + " visible=" + (r.height > 0 && r.width > 0) + extra);
    });
    var svgEl = document.querySelector("#diagram-wrap svg");
    lines.push("");
    lines.push("diagram-wrap > svg found: " + !!svgEl);
    if(svgEl){
      var svgR = svgEl.getBoundingClientRect();
      lines.push("svg: w=" + Math.round(svgR.width) + " h=" + Math.round(svgR.height) + " viewBox=" + svgEl.getAttribute("viewBox"));
    }
    lines.push("STATE.guide set: " + !!(window.STATE && window.STATE.guide));
    lines.push("STATE.diagramOrient: " + (window.STATE ? window.STATE.diagramOrient : "?"));
    var panel = document.getElementById("__layout_diag__");
    if(!panel){
      panel = document.createElement("div");
      panel.id = "__layout_diag__";
      panel.style.cssText = "position:fixed;bottom:0;left:0;right:0;z-index:99998;background:#052b1a;color:#7cffb0;font:10px/1.4 monospace;padding:8px 10px;max-height:50vh;overflow:auto;border-top:3px solid #32CCFE;white-space:pre-wrap;";
      document.body.appendChild(panel);
    }
    panel.textContent = "LAYOUT DIAGNOSTICS (tap logo 3x to hide):\n" + lines.join("\n");
  }
  var logoTapCount = 0, logoTapTimer = null;
  var brandEl = qs("#top-bar .brand");
  on(brandEl, "click", function(){
    logoTapCount++;
    clearTimeout(logoTapTimer);
    logoTapTimer = setTimeout(function(){ logoTapCount = 0; }, 600);
    if(logoTapCount >= 3){
      logoTapCount = 0;
      var panel = document.getElementById("__layout_diag__");
      if(panel){ panel.remove(); } else { showLayoutDiagnostics(); }
    }
  });

  // Service worker for offline/PWA support — optional, fails silently if sw.js is not present.
  if("serviceWorker" in navigator){
    window.addEventListener("load", function(){
      navigator.serviceWorker.register("sw.js").catch(function(){ /* no service worker file yet — app still works online */ });
    });
  }
});
</script>
<script>
/* --- ConesOut layout page opener (sandboxed, safe to remove) --- */
(function () {
  "use strict";
  try {
    var b = document.getElementById("openLayoutBtn");
    if (!b) { return; }
    b.addEventListener("click", function () {
      var url = "layout.html";
      try {
        var h = (window.STATE && window.STATE.home) ? window.STATE.home : null;
        if (h && h.roadType) {
          var setup = "half";
          if (h.impact === "full") { setup = "full"; }
          if (h.impact === "footpath") { setup = "foot"; }
          var road = "";
          var sp = Number(h.speed);
          if (h.roadType === "urban" || h.roadType === "rural") {
            if (sp <= 30) { road = "s30"; }
            else if (sp === 40) { road = "s40"; }
            else if (sp === 50) { road = "s50"; }
            else { road = "s60"; }
          } else if (h.roadType === "dual" && sp <= 40) {
            road = "d40";
          }
          url = "layout.html?setup=" + setup + (road ? "&road=" + road : "");
        }
      } catch (inner) {
        url = "layout.html";
      }
      window.open(url, "_blank");
    });
  } catch (outer) {
    /* never let this block break the app */
  }
})();
</script>
